# Kopieer naar .env in deze map (niet committen) en vul aan.
# Zie EMAILJS-SETUP.md voor uitleg (GitHub Pages + lokaal).

# EmailJS (template met {{title}} {{name}} {{time}} {{message}})
# Public key: Account → API keys. Service + template: dashboard EmailJS.
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
